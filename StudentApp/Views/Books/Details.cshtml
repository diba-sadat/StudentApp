@model StudentApp.Models.Books

@{
    ViewData["Title"] = "Book Details";
}

<h1>Book Details</h1>

@if (Model != null)
{
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">@Model.Name </h5>
            <dl class="row">
            </dl>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning">Book not found.</div>
}